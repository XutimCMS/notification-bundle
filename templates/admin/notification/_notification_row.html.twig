<div class="list-group-item p-0">
    <div class="row align-items-center g-0">
        <div class="col-auto px-3">
            <input
                type="checkbox"
                class="form-check-input"
                value="{{ notification.id }}"
                data-notification-select-target="checkbox"
                data-action="notification-select#toggle"
            />
        </div>
        <div class="col">
            <a
                href="{{ notification.actionUrl ?? '#' }}"
                class="list-group-item-action d-flex align-items-center gap-2 py-3 pe-3 text-reset text-decoration-none"
            >
                <span class="text-{{ notification.severity.statusColor() }}">
                    <twig:ux:icon :name="notification.severity.iconName()" class="icon" />
                </span>
                <div class="flex-fill text-truncate">
                    <div class="text-truncate{{ not notification.read ? ' fw-semibold' : ' text-secondary' }}">
                        {{ notification.title }}
                    </div>
                    <div class="text-secondary text-truncate small mt-1">
                        {{ notification.body }}
                    </div>
                </div>
                <span class="text-secondary text-nowrap small">
                    {{ notification.createdAt|format_datetime('short', 'short') }}
                </span>
                {% if not notification.read %}
                    <span class="badge bg-danger text-white">new</span>
                {% endif %}
            </a>
        </div>
    </div>
</div>
