{% extends '@XutimCore/admin/base.html.twig' %}

{% block pageTitle %}Notifications{% endblock %}

{% block breadcrumbHeader %}
    <twig:Xutim:Admin:Breadcrumbs>
        <li class="breadcrumb-item"><a href="{{ admin_path('admin_homepage') }}">Dashboard</a></li>
        <li class="breadcrumb-item">Notifications</li>
    </twig:Xutim:Admin:Breadcrumbs>
{% endblock %}

{% block pageMenu %}
    {% set unreadCount = notifications|filter(n => not n.read)|length %}
    {% if unreadCount > 0 %}
        <form method="post" action="{{ admin_path('admin_notification_read_all') }}">
            <twig:Xutim:Admin:Button variant="nav" tag="button" type="submit">
                <twig:ux:icon name="tabler:checks" class="icon me-1" />
                Mark all read ({{ unreadCount }})
            </twig:Xutim:Admin:Button>
        </form>
    {% endif %}
{% endblock %}

{% block body %}
    {% if notifications is empty %}
        <div class="card">
            <div class="empty">
                <div class="empty-icon">
                    <twig:ux:icon name="tabler:bell-off" style="width: 3rem; height: 3rem;" class="text-muted" />
                </div>
                <p class="empty-title">No notifications</p>
                <p class="empty-subtitle text-secondary">You're all caught up.</p>
            </div>
        </div>
    {% else %}
        <div data-controller="notification-select">
            <div class="card mb-3 d-none" data-notification-select-target="actions">
                <div class="card-body py-2">
                    <form method="post" action="{{ admin_path('admin_notification_bulk') }}" class="d-flex align-items-center gap-2">
                        <input type="hidden" name="action" value="" />
                        <span class="text-secondary">
                            <span data-notification-select-target="count">0</span> selected
                        </span>
                        <button type="button" class="btn btn-sm btn-primary" data-action="notification-select#markRead">
                            <twig:ux:icon name="tabler:mail-opened" class="icon me-1" />
                            Mark read
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-primary" data-action="notification-select#markUnread">
                            <twig:ux:icon name="tabler:mail" class="icon me-1" />
                            Mark unread
                        </button>
                    </form>
                </div>
            </div>

            {% set unread = notifications|filter(n => not n.read) %}
            {% set read = notifications|filter(n => n.read) %}

            {% if unread is not empty %}
                <div class="card mb-3">
                    <div class="card-header">
                        <h3 class="card-title d-flex align-items-center gap-2">
                            <input
                                type="checkbox"
                                class="form-check-input m-0"
                                data-notification-select-target="selectAll"
                                data-action="notification-select#toggleAll"
                            />
                            Unread
                            <span class="badge bg-primary text-white rounded-circle" style="width: 1.2rem; height: 1.2rem; font-size: .65rem; padding: 0; line-height: 1.2rem;">{{ unread|length }}</span>
                        </h3>
                    </div>
                    <div class="list-group list-group-flush list-group-hoverable">
                        {% for notification in unread %}
                            {% include '@XutimNotification/admin/notification/_notification_row.html.twig' %}
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {% if read is not empty %}
                <div class="card">
                    {% if unread is not empty %}
                        <div class="card-header">
                            <h3 class="card-title text-secondary">Earlier</h3>
                        </div>
                    {% endif %}
                    <div class="list-group list-group-flush list-group-hoverable">
                        {% for notification in read %}
                            {% include '@XutimNotification/admin/notification/_notification_row.html.twig' %}
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        </div>

        {% if notifications.nbPages > 1 %}
            <div class="card mt-3">
                <div class="card-footer d-flex align-items-center border-top">
                    <p class="m-0 text-muted">
                        Page {{ notifications.currentPage }} of {{ notifications.nbPages }}
                    </p>
                    <ul class="pagination m-0 ms-auto">
                        <li class="page-item{{ not notifications.hasPreviousPage ? ' disabled' }}">
                            <a
                                href="{{ notifications.hasPreviousPage ? admin_path('admin_notification_list', {page: notifications.previousPage}) : '#' }}"
                                class="page-link"
                            >
                                <twig:Xutim:Admin:Icon name="chevron-left" />
                                prev
                            </a>
                        </li>
                        <li class="page-item{{ not notifications.hasNextPage ? ' disabled' }}">
                            <a
                                href="{{ notifications.hasNextPage ? admin_path('admin_notification_list', {page: notifications.nextPage}) : '#' }}"
                                class="page-link"
                            >
                                next
                                <twig:Xutim:Admin:Icon name="chevron-right" />
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        {% endif %}
    {% endif %}
{% endblock %}
